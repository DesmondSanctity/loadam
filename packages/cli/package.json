{
 "name": "loadam",
 "version": "0.1.1",
 "description": "Loadam CLI — generate test rigs and MCP servers from API specs",
 "keywords": [
  "openapi",
  "k6",
  "load-testing",
  "contract-testing",
  "schemathesis",
  "mcp",
  "model-context-protocol",
  "cli"
 ],
 "homepage": "https://github.com/DesmondSanctity/loadam#readme",
 "repository": {
  "type": "git",
  "url": "git+https://github.com/DesmondSanctity/loadam.git",
  "directory": "packages/cli"
 },
 "bugs": {
  "url": "https://github.com/DesmondSanctity/loadam/issues"
 },
 "license": "Apache-2.0",
 "type": "module",
 "bin": {
  "loadam": "./dist/bin.js"
 },
 "files": [
  "dist"
 ],
 "scripts": {
  "build": "tsup",
  "dev": "tsup --watch",
  "test": "vitest run",
  "typecheck": "tsc --noEmit",
  "start": "node ./dist/bin.js",
  "prepack": "cp ../../README.md ../../LICENSE ."
 },
 "dependencies": {
  "@apidevtools/swagger-parser": "^10.1.0",
  "@faker-js/faker": "^9.3.0",
  "ajv": "^8.17.1",
  "ajv-formats": "^3.0.1",
  "commander": "^12.1.0",
  "consola": "^3.3.3",
  "json-schema-faker": "^0.5.6",
  "openapi-types": "^12.1.3",
  "yaml": "^2.7.0",
  "zod": "^3.24.1"
 },
 "devDependencies": {
  "@loadam/auth": "workspace:*",
  "@loadam/core": "workspace:*",
  "@loadam/graph": "workspace:*",
  "@loadam/mcp": "workspace:*",
  "@loadam/test-contract": "workspace:*",
  "@loadam/test-drift": "workspace:*",
  "@loadam/test-k6": "workspace:*",
  "@types/node": "^22.10.5",
  "tsup": "^8.3.5",
  "typescript": "^5.7.2",
  "vitest": "^2.1.8"
 },
 "publishConfig": {
  "access": "public"
 }
}